# Sumo Logic OAuth CLI – environment variables
# Copy to .env and fill in values.
# NEVER commit .env to git – it is listed in .gitignore.
#
# Recommended: store secrets in the OS keychain instead of this file.
#   sumo-oauth store-creds --client-id <CID>
#   sumo-oauth store-creds --access-id <AID>
#
# This file is loaded automatically if python-dotenv is installed:
#   uv pip install "sumo-oauth[dotenv]"

# Region (us1, us2, eu, au, de, jp, ca, in)
SUMO_REGION=us1

# OAuth client credentials – used by: login, token
SUMO_CLIENT_ID=
SUMO_CLIENT_SECRET=     # prefer keychain over storing here

# Basic auth credentials – used by: users, service-accounts, oauth-clients
SUMO_ACCESS_ID=
SUMO_ACCESS_KEY=        # prefer keychain over storing here
