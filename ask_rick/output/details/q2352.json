  "query": "_view=sumologic_search_usage_per_query {{{filter}}}\nstatus_message=\"Query Failed\"\n| (query_end_time - query_start_time)/1000 as range_s\n| round(range_s/60/60/24) as range_day\n| round(range_s/60/60,1) as range_hour\n//| range_s/60 as range_min\n| execution_duration_ms /1000 as duration_s\n// AGGREGATE TO GET STATS\n| substring(query,0,{{search_max_chrs}}) as query\n| values(range_hour) as ranges_hours, values(range_day) as ranges_days,sum(duration_s) as total_s,count as searches, sum(data_scanned_bytes) as bytes_scanned,  avg(duration_s) as avg_duration_s by query_type,user_name,query,status_message,analytics_tier\n| sort  bytes_scanned\n| bytes_scanned / 1G as gb_scan\n| fields -bytes_scanned",
