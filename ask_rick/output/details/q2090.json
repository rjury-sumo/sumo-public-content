{
  "id": "q2090",
  "hash": "f7343ffb7855",
  "queryType": "Logs",
  "queryMode": "Logs",
  "query": "_sourceCategory={{category}} {{search_keywords}}\n| \"{{search_keywords}}\" as sk\n| min(_messagetime) as f, max(_messagetime) as l, count by _sourcecategory,_collector,_source,sk,_view,_sourcename\n| sort _sourcecategory asc, _collector asc,_source asc\n\n// prepare the category strings\n| if(_view=\"\",\"SumologicDefault\",_view) as index\n| concat(\"_index=\",index) as  i\n| concat(\"_sourcecategory=\",_sourcecategory) as sc\n| concat(\"_collector=\",_collector) as c\n| concat(\"_source=\",_source) as s \n| concat(\"_sourcename=\",_sourcename) as sn\n\n| if(\"yes\" = \"{{add_index}}\",i,\"\") as i\n| if(\"yes\" = \"{{add_sourcecategory}}\",sc,\"\") as sc\n| if(\"yes\" = \"{{add_collector}}\",c,\"\") as c\n| if(\"yes\" = \"{{add_source}}\",s,\"\") as s\n| if(\"yes\" = \"{{add_sourcename}}\",sn,\"\") as sn\n\n| toint(floor((now()-f ) / (1000 * 60))) as f_min_ago\n| toint(ceil((now()-l ) / (1000 * 60))) as l_min_ago\n| concat(\"-\",f_min_ago,\"m -\",l_min_ago,\"m\") as rel_expression\n| fields -f_min_ago,l_min_ago\n\n// suppress scientific notation must be epoch\n| format( \"%.0f\",f) as f\n| format( \"%.0f\",l) as l\n\n// fix if they put a space in their stuff\n\n| replace(i,\" \",\"?\") as i\n| replace(sc,\" \",\"?\") as sc\n| replace(c,\" \",\"?\") as c\n| replace(s,\" \",\"?\") as s\n| replace(sn,\" \",\"?\") as sn\n\n\n// create one meta to avoid the 10 param limit on concat using multiple concats.\n| i as meta\n| concat (meta,\"\\n \",sc,\" \",c) as meta\n| concat (meta,\"\\n \",s,\" \",sn,\"\\n\") as meta\n| trim(meta) as meta\n| concat(meta,\"\\n \",sk) as search\n\n| tourl(concat(\"https://{{my_org}}/ui/#/search/@\",f,\",\",l,\"@\",urlencode(search)),\"Right Click Open Search Tab\") as  %\"Open This Search\" | fields -sc ,sk,c,s,f,l,i,sn,meta\n\n| sort _sourcecategory asc, _collector asc, _source asc, _view asc",
