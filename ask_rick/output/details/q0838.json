  "queryType": "Logs",
  "queryMode": "Logs",
  "query": "(_index=sec_record_*) \n| formatDate(_messagetime, \"yyyy-MM-dd HH:mm:ss:SSS\") as today \n| concat (description,\" from user \",user_username,\" on IP \",device_ip,\" and host \",device_hostname) as activity\n| where user_username matches \"{{user_username}}\"\n| first(today) as lastlogon\n| count by lastlogon\n| fields -_count",
