  "query": "_index=sumologic_volume sizeInBytes \n_sourceCategory=view_volume\n\n| parse regex \"\\\"(?<view>[^\\\"]+)\\\"\\:\\{\\\"sizeInBytes\\\"\\:(?<bytes>\\d+),\\\"count\\\"\\:(?<count>\\d+)\\}\" multi\n\n| if(view matches \"_sumologic_report*\",\"saved_views\",view) as view\n//| if(view matches \"*volume*\",\"internal\",view) as view\n| timeslice by {{timeslice}} \n\n| sum(bytes) as size_in_bytes by view,_timeslice\n| size_in_bytes / 1024 / 1024 / 1024 as gbytes\n\n| sum(gbytes) as gbytes by view,_timeslice\n| \"continuous\" as tier\n| if(view matches /{{freq_regex}}/,\"frequent\",tier) as tier\n| if(view matches /{{infreq_regex}}/,\"infrequent\",tier) as tier\n| if (view matches /(?)CSE_[RS][ei]/,\"cse_data\",tier) as tier\n\n| 20 as cr_cont\n| 25 as cr_cse\n| 9 as cr_freq\n| 0.4 as cr_infreq\n| if (tier = \"continuous\",cr_cont * gbytes * ((100 - {{cse_pct}})  /100),0) as cr_continuous\n| if (tier = \"continuous\",cr_cse * gbytes * ({{cse_pct}}  /100),0) as cr_cse\n| if (tier = \"frequent\",cr_freq * gbytes,0) as cr_frequent\n| if (tier = \"infrequent\",cr_infreq * gbytes,0) as cr_infrequent\n\n| concat(\"cr_continuous:\",cr_continuous,\"cr_cse:\",cr_cse,\"cr_frequent:\",cr_frequent,\"cr_infrequent:\",cr_infrequent) as transport\n| parse regex field = transport \"(?<type>[a-z_]+):(?<credits>[0-9]+)\" multi\n\n|  sum(credits) by type, _timeslice | transpose row _timeslice column type",
