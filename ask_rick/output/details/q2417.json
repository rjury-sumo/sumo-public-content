  "query": "cat path://\"{{lookup_path}}\"\n| tourl(trim(link),concat(\"Open: \",trim(link))) as link\n| where tolowercase(title) matches tolowercase(\"{{search_title}}\")\n| where title matches /(?i){{regex_title}}/\n| parse regex field=title \"(?<word>\\w+)\" multi\n| count by word\n| where length(word) > 3\n//| where !(word in (\"Micro\",\"lesson\",\"Lesson\")) \n| sort word asc\n| 1 as i\n| now() as _messagetime\n| transactionize i (merge i takefirst, word join with \" \") \n| count by word | fields -_count",
