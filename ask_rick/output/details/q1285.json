  "queryType": "Logs",
  "queryMode": "Logs",
  "query": "_index=sumologic_volume datapoints\n _sourceCategory = \"sourcecategory_metrics_volume\"\n| parse regex \"\\\"(?<collector>[^\\\"]+)\\\"\\:\\{\\\"dataPoints\\\"\\:(?<datapoints>\\d+)\\}\" multi\n| timeslice 1d\n| max(__timeslice_end) as tse, sum(datapoints) as datapoints by _timeslice,collector\n| (tse-_timeslice) /1000 / 60 as slice_minutes\n| datapoints / slice_minutes as Dpm\n// dpms are measured in 24 hour averages\n| ((dpm / (60 * 24))/1000) * 3 as credits\n| sum(credits) as credits\n\n| {{my_annual_credits}} / {{credit_term_days}} as plan\n\n| ( queryendtime() - querystarttime() ) / ( 1000 * 60 * 60 * 24) as query_days\n| credits / query_days as %\"cr/day\" // \n| {{my_annual_credits}} / {{credit_term_days}} as plan\n| ( %\"cr/day\"/plan ) * 100 as pct_plan\n| fields -plan,query_days",
