  "query": "_index=sumologic_volume _sourcecategory=sourcecategory_and_tier_volume\n\n// Excluding current day (incomplete data set)\n| formatdate(now(), \"YYYY-MM-dd\") as currenDay\n| formatdate(_messageTime, \"YYYY-MM-dd\") as eventDay\n| where eventDay != currenDay\n\n// Excluding first day in the query (incomplete data set)\n| formatdate(queryStartTime(), \"YYYY-MM-dd\") as queryStartDay\n| where eventDay != queryStartDay\n\n// Parsing events \n| parse regex \"\\{\\\"field\\\":\\\"(?<sourcecategory>[^\\\"]*)\\\",\\\"dataTier\\\":\\\"(?<tier>[^\\\"]*)\\\",\\\"sizeInBytes\\\":(?<bytes>\\d*),\\\"count\\\":(?<events>\\d*)}\" multi nodrop\n| where tier = \"CSE\"\n\n// Discarding internal values\n| where !(sourcecategory matches \"*_volume\")\n\n// Aggregating per day - sum of bytes as GBytes per data tier\n| timeslice 1d\n| sum(bytes) as bytes by _timeslice, tier\n| bytes/1Gi as GBytes\n\n// Calculating credit cost per Gbyte per data tier\n| {{INGEST_CSE}} as credit_cost\n\n// Calculating the sum of credits used per day\n| (GBytes*credit_cost) as credits\n| sum(credits) as credits by _timeslice\n| order by _timeslice\n\n// Average credit consumption trend\n| smooth credits as trend\n\n| fields _timeslice, credits, trend",
