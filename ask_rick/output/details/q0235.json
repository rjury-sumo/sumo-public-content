  "query": "cat {{{lookup}}}\n| where createdtime > (now () - (1000 * 60 * 60 * 24 * {{days}}))\n| formatdate(tolong(createdtime),\"yyyy-MM\") as month\n| where status= \"closed\"\n| if(resolution = \"False Positive\", 1, 0) as fp_count\n| if(resolution = \"No Action\",1,0) as no_act_count\n| 1 as _row\n| count as insights,avg(confidence) as confidence_score,sum(fp_count) as fp_count,sum(no_act_count) as no_act_count by month\n| 100 * (fp_count/insights) as fp_ratio\n| 100 * (no_act_count/insights) as no_action_rato\n| sum(insights) as insights //,avg(fp_ratio) as fp_ratio ,avg(no_action_rato) as no_action_rato \nby month\n| order by month asc",
