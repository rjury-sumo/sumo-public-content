  "queryType": "Logs",
  "queryMode": "Logs",
  "query": "cat {{{lookup}}}\n| where time > (now () - (1000 * 60 * 60 * 24 * 365))\n| formatdate(tolong(time),\"yyyy-MM\") as month\n| where status= \"closed\"\n| if(resolution = \"False Positive\", 1, 0) as fp_count\n| 1 as _row\n| count as insights,avg(confidence) as confidence_score,sum(fp_count) as fp_count by month\n| 100 * (fp_count/insights) as fp_ratio\n| sum(insights) as insights,avg(fp_ratio) as fp_ratio by month",
