  "queryMode": "Logs",
  "query": "_index=sumologic_search_usage_per_query\n  AND !(status_message = \"Query canceled\")\n  AND !(user_name = security+sumosupport+*@sumologic.com) \n\n// Excluding current day (incomplete data set)\n| formatdate(now(), \"YYYY-MM-dd\") as currenDay\n| formatdate(_messageTime, \"YYYY-MM-dd\") as eventDay\n| where eventDay != currenDay\n\n// Excluding first day in the query (incomplete data set)\n| formatdate(queryStartTime(), \"YYYY-MM-dd\") as queryStartDay\n| where eventDay != queryStartDay\n\n// selecting FLEX scans only\n| json field=scanned_bytes_breakdown_by_metering_type \"Flex\" as bytes nodrop\n\n// Aggregating per day - sum of bytes as GBytes per data tier\n| timeslice 1d\n| sum(bytes) as bytes by _timeslice\n| bytes/1Ti as tbytes\n\n| {{SCAN}} as credit_cost\n\n// Calculating the sum of credits used per day\n| tbytes * credit_cost as credits\n| sum(credits) as credits by _timeslice\n| order by _timeslice\n\n// Prediction\n| predict credits by 1d forecast=30\n| credits_predicted as predicted\n\n\n| fields _timeslice, predicted",
