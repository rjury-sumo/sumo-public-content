  "query": "_index=sumologic_volume _sourcecategory={{INGEST_DIMENSION}}_metrics_volume\n\n\n| parse regex \"\\\"(?<{{INGEST_DIMENSION}}>[^\\\"]*)\\\":\\{\\\"dataPoints\\\":(?<datapoints>\\d+)\\}\" multi nodrop\n\n| timeslice 1d\n| sum(datapoints) as datapoints by _timeslice, {{INGEST_DIMENSION}}\n| datapoints / 24 / 60 / 1000 as DPM\n\n| sum(DPM) as DPM by {{INGEST_DIMENSION}}\n\n| {{INGEST_METRICS}} as credit_cost\n\n| round(DPM*credit_cost) as credits\n| round(DPM,1) as DPM\n\n| fields -credit_cost\n\n| order by credits desc",
