  "query": "_index=sumologic_volume _sourcecategory=sourcecategory_tracing_volume\n\n// Excluding current day (incomplete data set)\n| formatdate(now(), \"YYYY-MM-dd\") as currenDay\n| formatdate(_messageTime, \"YYYY-MM-dd\") as eventDay\n| where eventDay != currenDay\n\n// Excluding first day in the query (incomplete data set)\n| formatdate(queryStartTime(), \"YYYY-MM-dd\") as queryStartDay\n| where eventDay != queryStartDay\n\n// Parsing events \n| parse regex \"\\\"(?<sourcecategory>[^\\\"]*)\\\":\\{\\\"billedBytes\\\":(?<bytes>\\d+)\" multi nodrop\n\n// Aggregating per day - sum of bytes\n| timeslice 1d\n| sum(bytes) as bytes by _timeslice\n\n| bytes/1Gi as GBytes\n\n// Calculating credit cost per bytes\n| {{INGEST_TRACING}} as credit_cost\n\n// Calculating the sum of credits used per day\n| (GBytes*credit_cost) as credits\n| sum(credits) as credits by _timeslice\n| avg(credits) as credits\n| round(credits) as credits",
