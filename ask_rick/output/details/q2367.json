  "queryType": "Logs",
  "queryMode": "Logs",
  "query": "_index=sumologic_volume sizeInBytes \n_sourceCategory=view_volume\n\n| parse regex \"\\\"(?<view>[^\\\"]+)\\\"\\:\\{\\\"sizeInBytes\\\"\\:(?<bytes>\\d+),\\\"count\\\"\\:(?<count>\\d+)\\}\" multi\n\n| if(view matches \"_sumologic_report*\",\"saved_views\",view) as view\n//| if(view matches \"*volume*\",\"internal\",view) as view\n| min(_messagetime) as s, max(_messagetime) as e , sum(bytes) as size_in_bytes by view\n| size_in_bytes / 1024 / 1024 / 1024 as gbytes\n| sum(gbytes) as gbytes by view,s,e\n| \"continuous\" as tier\n| if(view matches /{{freq_regex}}/,\"frequent\",tier) as tier\n| if(view matches /{{infreq_regex}}/,\"infrequent\",tier) as tier\n| if (view matches /(?)CSE_[RS][ei]/,\"cse_data\",tier) as tier\n| sum(gbytes) as gbytes by tier\n\n| 20 as cr_cont\n| 25 as cr_cse\n| 9 as cr_freq\n| 0.4 as cr_infreq\n| cr_cont * gbytes * ((100 - {{cse_pct}} ) /100) as cr_cont\n| cr_cse * gbytes * ({{cse_pct}} /100)  as cr_cse\n| if (tier = \"continuous\", cr_cont+cr_cse ,0) as credits\n| if (tier = \"frequent\",cr_freq * gbytes,credits) as credits\n| if (tier = \"infrequent\",cr_infreq * gbytes,credits) as credits\n\n\n| if(tier  = \"frequent\",gbytes,0) as frequent\n| if (tier = \"continuous\",gbytes,0) as continuous\n| if(tier = \"infrequent\",gbytes,0) as infrequent\n| sum(continuous) as continuous,sum(frequent) as frequent, sum(infrequent) as infrequent\n\n| 20 as cr_cont\n| 25 as cr_cse\n| cr_cont * continuous * ((100 - {{cse_pct}} ) /100) as cr_cont\n| cr_cse * continuous * ({{cse_pct}} /100)  as cr_cse\n\n| ( cr_cont + cr_cse  + (frequent * 9) +  (infrequent * .4)  ) / (continuous + frequent + infrequent) as CPGI | avg(CPGI) as CPGI",
