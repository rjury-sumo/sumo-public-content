  "queryType": "Logs",
  "queryMode": "Logs",
  "query": "_index=sec_signal\n| formatDate(toLong(createdTimestamp), \"yyyy-MM-dd HH:mm:ss\") as timestamp\n| json field=entities \"[0].type\" as entity_type nodrop\n| where entity_type matches \"*username\"\n| json field=entities \"[0].value\" as user_username nodrop\n| where user_username matches \"{{user_username}}\"\n| urlencode(id) as signalId\n| concat(\"https://\",\"{{service_endpoint}}\",\".sumologic.com/sec/signal/\",signalId,\"\") as url\n| tourl(url,name) as ruleName\n| concat (\"User \",user_username,\" triggered an alert on the Signal: \",ruleName) as activity\n| count by activity,timestamp\n| sort by timestamp asc\n| fields -_count",
