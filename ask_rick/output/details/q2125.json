  "query": "(_index=sumologic_volume _sourceCategory=byMetricDataPoints) \n| parse \"intervalStart: *\\n\" as interval\n| parse regex \"\\n(?<singleRecord>.*)\" multi\n| split singleRecord delim=';' extract 1 as metric, 2 as dp\n| where metric matches /{{metric_matches}}/\n| timeslice {{timeslice}}\n| (__timeslice_end - _timeslice)/ (1000 * 60) as ts_min\n|max(ts_min) as ts_min, sum(dp) as totalDp group by _timeslice\n| round(totalDp / ts_min, 0) as dpm | fields -ts_min,totaldp\n| compare with timeshift {{compare_with}}",
