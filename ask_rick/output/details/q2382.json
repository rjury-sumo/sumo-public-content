  "query": "( _view=data_volume_custom_* )\ndimension ={{view}}\nitem={{value_filter}}\ndatatier = {{tier_filter}}\n| sum(events) as events, sum(credits) as credits,sum(gbytes) as gbytes by datatier,dimension, item\n| item as i\n// remove long categories\n| if (length(item) > {{max_chrs}},concat(substring(item,0,{{max_chrs}}),\"...\"),item) as item\n| count_distinct(i) as categories,sum(events) as events, sum(credits) as credits,sum(gbytes) as gbytes by datatier,dimension,item\n\n| credits/gbytes as %\"cr/gb\"\n| sort credits\n| total credits as tc | (credits/tc) * 100 as cr_pct | fields -tc",
