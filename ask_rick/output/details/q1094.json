  "query": "_index=sumologic_audit_events _sourceCategory=userSessions (UserLoggedOut OR UserLoggedIn OR UserLoginTimedOut)\n| json \"eventName\", \"userSession.id\", \"sessionIdentity.userId\", \"userSession.sourceIp\"  as EventName, LoginUserId, LogoutUserID, UserIp nodrop\n| where EventName in (\"UserLoggedOut\",\"UserLoggedIn\",\"UserLoginTimedOut\")\n| where EventName matches \"{{EventName}}\" and UserIp matches \"{{UserIp}}\" \n| if(isNull(LoginUserId), LogoutUserID, LoginUserId) as UserId\n| withtime EventName\n| most_recent(EventName_withtime) as LastEvent by UserId\n| where UserId!=\"-\"\n| where LastEvent matches \"UserLoggedIn\"\n| count as Count by LastEvent\n| fillmissing values(\"UserLoggedIn\") in LastEvent",
