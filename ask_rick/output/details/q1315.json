  "queryType": "Logs",
  "queryMode": "Logs",
  "query": "_index=\"sumologic_volume\"\nAND _sourcecategory = \"granular_volume\"\n\n{{keywords}}\n//// built in\n| json field=_raw \"messageTier\" as datatier | where datatier matches \"{{datatier}}\"\n| json field=_raw \"sizeInBytes\" as bytes  \n| json field=_raw \"messageCount\" as events \n| json field=_raw \"viewName\"  as index | where index matches \"{{partition}}\"\n//\n//// defined in feature flag\n| json field=_raw \"collectorName\" as collector nodrop | where collector matches \"{{collector}}\"\n| json field=_raw \"sourceCategory\"  nodrop | where sourcecategory matches \"{{sourcecategory}}\"\n| json field=_raw \"bladeName\" as source nodrop\n\n|  sum(events) as events by datatier,index,sourcecategory\n| if(index=\"Default Index\",\"sumologic_default\",index) as index\n| concat(\"_index=\",index,\" _sourcecategory=\",replace(sourcecategory,\" \",\"?\")) as query_scope\n\n| limit 1000 | sort sourcecategory asc, index asc\n\n// prepare the category strings\n\n| concat(\"_index=\",index) as  i\n| concat(\"_sourcecategory=\",sourcecategory) as sc\n//| concat(\"\\n_collector=\",collector) as c\n//| concat(\"\\n_source=\",source) as s \n\n// fix if they put a space in their stuff\n| replace(i,\" \",\"?\") as i\n| replace(sc,\" \",\"?\") as sc\n//| replace(c,\" \",\"?\") as c\n//| replace(s,\" \",\"?\") as s\n\n// create one meta to avoid the 10 param limit on concat using multiple concats.\n| i as meta\n| concat (meta,\"\\n \",sc) as meta\n//| concat (meta,\"\\n // \",c,\"\\n //\",s,\" \") as meta\n| trim(meta) as meta\n\n| tourl(concat(\"https://{{my_instance_name}}/log-search/create?query=\",urlencode(meta)),\"»»\") as  %\"Open in Search\" \n| fields -i,sc,meta",
