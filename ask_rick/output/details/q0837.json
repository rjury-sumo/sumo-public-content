  "query": "(_index=sec_record_*) \n| formatDate(_messagetime, \"yyyy-MM-dd hh a\") as today \n| concat (description,\" from user \",user_username,\" on IP \",device_ip,\" and host \",device_hostname) as activity\n| where user_username matches \"{{user_username}}\"\n| lookup latitude, longitude, country_code, country_name, region, city, postal_code from geo://location on ip = device_ip\n| count by latitude, longitude, country_code, country_name, region, city, postal_code\n| sort _count",
