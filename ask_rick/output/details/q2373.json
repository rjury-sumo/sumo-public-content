  "query": "_index=sumologic_volume dataPoints\n| where _sourceCategory=\"sourcecategory_metrics_volume\"\n| parse regex \"\\\"(?<sourcecategory>[^\\\"]+)\\\"\\:\\{\\\"dataPoints\\\"\\:(?<datapoints>\\d+)\\}\" multi\n| timeslice by {{timeslice}}\n|min(_messagetime) as f, max(_messagetime) as l , sum(datapoints) as datapoints by _timeslice,sourcecategory\n| ((l - f)/(1000*60)) as duration_in_min\n| datapoints / duration_in_min as dpm\n| (dpm)/1000  * 3 * ( duration_in_min / ( 60 * 24))  as cr_metrics\n| fields _timeslice, cr_metrics,sourcecategory\n| transpose row _timeslice column sourcecategory",
