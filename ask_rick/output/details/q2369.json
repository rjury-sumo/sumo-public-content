  "query": "_index=sumologic_volume sizeInBytes \n_sourceCategory=view_volume\n\n| parse regex \"\\\"(?<view>[^\\\"]+)\\\"\\:\\{\\\"sizeInBytes\\\"\\:(?<bytes>\\d+),\\\"count\\\"\\:(?<count>\\d+)\\}\" multi\n\n| if(view matches \"_sumologic_report*\",\"saved_views\",view) as view\n//| if(view matches \"*volume*\",\"internal\",view) as view\n| timeslice by {{timeslice}} \n\n| sum(bytes) as size_in_bytes by view,_timeslice\n| size_in_bytes / 1024 / 1024 / 1024 as gbytes\n//| concat(deployment,\"_\",org_id) as key\n//| lookup org_id,org_name,daily_gb_limit from /shared/lookups/master_orgs on key=key  \n| sum(gbytes) as gbytes by view,_timeslice\n| sum(gbytes) as gbytes by view,_timeslice\n| \"continuous\" as tier\n| if(view matches /{{freq_regex}}/,\"frequent\",tier) as tier\n| if(view matches /{{infreq_regex}}/,\"infrequent\",tier) as tier\n| if (view matches /(?)CSE_[RS][ei]/,\"cse_data\",tier) as tier\n\n| 20 as cr_cont\n| 25 as cr_cse\n| 9 as cr_freq\n| 0.4 as cr_infreq\n| if (tier = \"continuous\",gbytes * ((100 - {{cse_pct}})  /100),0) as continuous\n| if (tier = \"continuous\",gbytes * ({{cse_pct}}  /100),0) as cse\n| if (tier = \"frequent\",gbytes,0) as frequent\n| if (tier = \"infrequent\",gbytes,0) as infrequent\n\n| concat(\"continuous:\",continuous,\"cse:\",cse,\"frequent:\",frequent,\"infrequent:\",infrequent) as transport\n| parse regex field = transport \"(?<type>[a-z_]+):(?<gbytes>[0-9]+)\" multi\n\n|  sum(gbytes) by type, _timeslice | transpose row _timeslice column type",
