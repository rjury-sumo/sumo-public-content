  "query": "_index=sumologic_volume sizeInBytes \n_sourceCategory=view_volume\n\n| parse regex \"\\\"(?<view>[^\\\"]+)\\\"\\:\\{\\\"sizeInBytes\\\"\\:(?<bytes>\\d+),\\\"count\\\"\\:(?<count>\\d+)\\}\" multi\n\n| if(view matches \"_sumologic_report*\",\"saved_views\",view) as view\n//| if(view matches \"*volume*\",\"internal\",view) as view\n| timeslice by {{timeslice}} \n\n| sum(bytes) as size_in_bytes by view,_timeslice\n| size_in_bytes / 1024 / 1024 / 1024 as gbytes\n| sum(gbytes) as gbytes by view,_timeslice\n\n| \"continuous\" as tier\n| if(view matches /{{freq_regex}}/,\"frequent\",tier) as tier\n| if(view matches /{{infreq_regex}}/,\"infrequent\",tier) as tier\n| if (view matches /(?)CSE_[RS][ei]/,\"cse_data\",tier) as tier\n\n| where tier = \"infrequent\"\n| view as index\n| if (index matches \"*sumologic*\",\"sumologic_internal\",index) as index\n|  sum(gbytes) as gbytes by index,_timeslice\n| transpose row _timeslice column index",
