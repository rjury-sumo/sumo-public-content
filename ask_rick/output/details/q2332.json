  "queryType": "Logs",
  "queryMode": "Logs",
  "query": "(_view=sumologic_search_usage_per_query) \nnot query_type=sumo* not user_name=*sumosupport*\nuser_name={{user_name}} query={{query_pattern}} query_type={{query_type}} analytics_tier={{tier}}\n| where query matches /{{query_regex}}/\n//| ((query_end_time - query_start_time ) /1000 / 60 ) as time_range_m\n//| sort execution_duration_ms\n| json field=scanned_bytes_breakdown \"Infrequent\" as inf_scan_bytes nodrop\n| json field=scanned_bytes_breakdown \"Frequent\" as f_scan_bytes nodrop\n| json field=scanned_bytes_breakdown \"Continuous\" as c_scan_bytes nodrop\n\n| if (isnull(inf_scan_bytes),0,inf_scan_bytes) as inf_scan_bytes\n| if (isnull(f_scan_bytes),0,f_scan_bytes) as f_scan_bytes\n| if (isnull(c_scan_bytes),0,c_scan_bytes) as c_scan_bytes\n\n| count as searches,  sum(inf_scan_bytes) as inf_scan_bytes,sum(c_scan_bytes) as c_scan_bytes, sum(f_scan_bytes) as f_scan_bytes by user_name,query_type\n| round((inf_scan_bytes /1024/1024/1024) * 10 )/10 as inf_scan_gb\n| round((f_scan_bytes /1024/1024/1024) * 10 )/10 as f_scan_gb\n| round((c_scan_bytes /1024/1024/1024) * 10 )/10 as c_scan_gb\n\n| count_distinct(user_name) as users, sum(searches) as searches, sum(c_scan_gb) as c_scan_gb, sum(inf_scan_gb) as inf_scan_gb, sum(f_scan_gb) as f_scan_gb by query_type\n| inf_scan_gb * .016 as inf_scan_credits | sort query_type asc",
