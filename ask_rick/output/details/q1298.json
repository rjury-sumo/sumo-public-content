  "query": "cat {{{lookup}}}\n| where _timeslice > ( now() - ({{days}} * 1000 * 60 * 60 * 24))\n| avg(avg_units) as avg_units,sum(units) as units,sum(credits) as credits by uom,rate,unit,_timeslice\n| avg(avg_units) as avg_units,sum(units) as units,sum(credits) as credits,avg(credits) as %\"cr/day\" by uom,rate,unit\n\n| {{my_annual_credits}} / {{credit_term_days}} as plan\n| ( %\"cr/day\"/plan ) * 100 as pct_plan\n| fields -plan\n| sort uom asc",
