  "queryType": "Logs",
  "queryMode": "Logs",
  "query": "_sourceCategory={{category}} {{search_keywords}}\n| \"{{search_keywords}}\" as sk\n| _view as index\n| count_distinct(_collector) as collectors, count_distinct(_source) as sources, count_distinct(_sourcename) as sourcenames,min(_messagetime) as f, max(_messagetime) as l, count by _sourcecategory,index\n| if(isempty(index),\"SumologicDefault\",index) as index\n| formatdate(tolong(f),\"yyyy/MM/dd HH:mm:ss ZZZ\") as first_event\n| formatdate(tolong(l),\"yyyy/MM/dd HH:mm:ss ZZZ\") as last_event\n| round((l-f) / (1000 * 60)) as range_min\n| toint(floor((now()-f ) / (1000 * 60))) as f_min_ago\n| toint(ceil((now()-l ) / (1000 * 60))) as l_min_ago\n| concat(f_min_ago,\"m \",l_min_ago,\"m\") as rel_expression\n| fields -f,l,f_min_ago,l_min_ago\n| sort _sourcecategory asc,index asc",
