  "query": "_index=\"sumologic_volume\"\nAND _sourcecategory = \"granular_volume\"\n\n{{keywords}}\n//// built in\n| json field=_raw \"messageTier\" as datatier | where datatier matches \"{{datatier}}\"\n| json field=_raw \"sizeInBytes\" as bytes  \n| json field=_raw \"messageCount\" as events \n| json field=_raw \"viewName\"  as index | where index matches \"{{partition}}\"\n//\n//// defined in feature flag\n| json field=_raw \"collectorName\" as collector nodrop | where collector matches \"{{collector}}\"\n| json field=_raw \"sourceCategory\"  nodrop | where sourcecategory matches \"{{sourcecategory}}\"\n| json field=_raw \"bladeName\" as source nodrop\n//\n| timeslice 5m\n| sum(bytes) as bytes, sum(events) as events by datatier, collector,sourcecategory,source,index\n\n// add credits from contract for tiers\n| 20 as cr_rate \n| if (datatier = \"Infrequent\",.4,cr_rate) as cr_rate\n| if (datatier = \"Frequent\",9,cr_rate) as cr_rate\n| if (datatier = \"CSE\",25,cr_rate) as cr_rate\n| bytes / 1Gi as gb | fields - bytes\n| cr_rate * gb as credits \n| round(gb,2) as gb | round(credits,2) as credits\n| sort credits | limit 1000",
