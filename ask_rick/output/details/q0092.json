  "query": "(_index=sumologic_volume) _sourcecategory={{data_volume_view}}_and_tier_volume\n| parse regex \"\\{\\\"field\\\":\\\"(?<value>[^\\\"]+)\\\",\\\"dataTier\\\":\\\"(?<dataTier>[^\\\"]+)\\\",\\\"sizeInBytes\\\":(?<sizeInBytes>[^\\\"]+),\\\"count\\\":(?<count>[^\\\"]+)\\}\" multi\n| where tolowercase(value) matches tolowercase(\"*\")\n| where datatier matches \"*\"\n| timeslice {{timeslice}}\n| sizeInBytes / 1024/1024/1024 as gb\n// remove long categories\n| if (length(value) > {{value_max_chr}},concat(substring(value,0,{{value_max_chr}}),\"*\"),value) as value \n| sum(events) as events,sum(gb) as gbytes by value,_timeslice,datatier\n| total gbytes as tgb \n| total gbytes as tgbs by value\n| tgbs / tgb as fraction\n\n// *** THIS LINE rolls up small sources into 'other' ***\n| if(( fraction * 100 )> .1,value,\"other\" ) as value\n| fraction * 100 as percent\n//|count as rows, sum(events) as events,sum(gbytes) as gbytes, sum(percent) as percent by view,value\n//| sort percent\n\n\n\n| sum(gbytes) as gbytes by _timeslice,value \n| transpose row _timeslice column value",
