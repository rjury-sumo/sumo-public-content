  "query": "_sourcecategory={{sourcecategory}}\n// subquery will give us a sample set of 100 messageids for this same sourcecategory\n[subquery:\n_index=sec_record_failure \n metadata_sourcecategory={{sourcecategory}} {{{search_term}}}\n| limit 100\n| count by _sourcecategory ,metadata_sourceCategory,metadata_sourceMessageId \n| metadata_sourceMessageId as _messageid\n| metadata_sourceCategory as _sourcecategory | count by _sourcecategory,_messageid | compose _sourcecategory,_messageid]\n| limit 100\n| concat(\"_sourcecategory=\",_sourcecategory,\"\\n _messageid=\",_messageid) as log_search\n| count by log_search,_raw",
