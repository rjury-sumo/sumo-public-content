  "queryType": "Logs",
  "queryMode": "Logs",
  "query": "_index=sumologic_volume sizeInBytes \n_sourceCategory=view_volume\n\n| parse regex \"\\\"(?<view>[^\\\"]+)\\\"\\:\\{\\\"sizeInBytes\\\"\\:(?<bytes>\\d+),\\\"count\\\"\\:(?<count>\\d+)\\}\" multi\n\n| sum(bytes) as size_in_bytes by view\n| size_in_bytes / 1024 / 1024 / 1024 as gbytes\n| sum(gbytes) as gbytes by view\n\n| \"continuous\" as tier\n| if(view matches /{{freq_regex}}/,\"frequent\",tier) as tier\n| if(view matches /{{infreq_regex}}/,\"infrequent\",tier) as tier\n| if (view matches /(?)CSE_[RS][ei]/,\"cse_data\",tier) as tier\n| view as rename_for_report\n| if(view matches \"_sumologic_report*\",\"saved_views\",view) as rename_for_report\n| if (view matches \"*sumologic*\",\"sumologic_internal\",rename_for_report) as rename_for_report\n| 20 as cr_cont\n| 9 as cr_freq\n| 0.4 as cr_infreq\n| if (tier = \"continuous\",cr_cont * gbytes,0) as ingest_credits_consumed\n| if (tier = \"frequent\",cr_freq * gbytes,ingest_credits_consumed) as ingest_credits_consumed\n| if (tier = \"infrequent\",cr_infreq * gbytes,ingest_credits_consumed) as ingest_credits_consumed\n| gbytes as gbytes\n| sort ingest_credits_consumed\n| fields -cr_cont,cr_freq,cr_infreq\n| ingest_credits_consumed / gbytes as CPGI",
