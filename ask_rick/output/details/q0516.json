  "queryType": "Logs",
  "queryMode": "Logs",
  "query": "_index=sumologic_volume _sourceCategory=\"sourcecategory_and_tier_volume\"\n| parse regex \"(?<data>\\{[^\\{]+\\})\" multi\n| json field=data \"field\",\"dataTier\",\"sizeInBytes\",\"count\" as sourcecategory, dataTier, bytes, count\n|where dataTier matches \"{{Tier}}\"\n| bytes/1Gi as gbytes \n| sum(gbytes) as gbytes by sourcecategory\n| round(gbytes,2) as gbytes\n| total gbytes as tot_gbytes \n| round(tot_gbytes,2) as tot_gbytes\n| (gbytes*100/tot_gbytes) as pct_total \n| round(pct_total,2) as pct_total \n| where pct_total >= 1 and pct_total <= 30 // candidates for partition\n| sort pct_total",
