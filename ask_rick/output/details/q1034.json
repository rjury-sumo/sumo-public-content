  "query": "_index=sumologic_audit_events _sourceCategory=users (UserCreated OR UserUpdated OR UserDeleted)\n| json \"eventName\", \"userIdentity.userId\", \"user.active\", \"to.active\", \"operator.email\", \"operator.sourceIp\" as EventName, UserId, ActiveCreated, ActiveUpdated,  Admin, AdminIp nodrop\n| where EventName in (\"UserCreated\",\"UserUpdated\", \"UserDeleted\")\n| where  EventName matches \"{{EventName}}\" and Admin matches \"{{Admin}}\" and AdminIp matches \"{{AdminIp}}\"\n| if(isNull(ActiveCreated), if(isNull(ActiveUpdated), \"-\", ActiveUpdated) ,ActiveCreated) as CurrentActive\n| withtime CurrentActive\n| most_recent(CurrentActive_withtime) as Status by UserId\n| where Status!=\"-\"\n| count as Count by Status\n| if(Status matches \"true\", \"Active\", \"InActive\") as Status",
